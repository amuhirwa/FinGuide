# FinGuide Backend Environment Variables
# =======================================
# Copy this file to .env and update with your values

# Project
PROJECT_NAME=FinGuide API
VERSION=1.0.0
ENVIRONMENT=development

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=sqlite:///./finguide.db

# CORS (comma-separated origins)
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Twilio SMS OTP
# Obtain from https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# The verified sender number or Messaging Service SID (+E.164 format)
TWILIO_PHONE_NUMBER=+12015551234
# OTP validity window in minutes
OTP_EXPIRE_MINUTES=5
